PG_EXPORTER_PASSWORD=CHANGE_ME
# Senha do admin do Grafana.
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
# Senha do Redis (192.168.30.100). Deixe vazio se o Redis não tem auth.
GPU_BRIDGE_REDIS_PASSWORD=
