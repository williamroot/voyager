DJANGO_SECRET_KEY=changeme-generate-with-django-management-or-secrets-token-urlsafe-50
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=America/Sao_Paulo

DATABASE_URL=postgres://voyager:voyager@postgres:5432/voyager
REDIS_URL=redis://redis:6379/0

DJEN_BASE_URL=https://comunicaapi.pje.jus.br/api/v1/comunicacao
DJEN_REQUEST_TIMEOUT_CONNECT=10
DJEN_REQUEST_TIMEOUT_READ=60
DJEN_PAGE_SLEEP_SECONDS=1.0
DJEN_MAX_RETRIES=5
DJEN_USER_AGENT=voyager-ingestion/0.1

PROXYSCRAPE_API_KEY=
PROXYSCRAPE_REFRESH_SECONDS=900
CORTEX_PROXY_URL=
CORTEX_FALLBACK_ENABLED=true
PROXY_BAD_TTL_SECONDS=600

SLACK_WEBHOOK_URL=
SLACK_NOTIFY_DRIFT=true
SLACK_NOTIFY_FAILED_RUN=true

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.05

# Classificação de IP em cadastros via /invite/<token>/.
# Vazio = endpoint free do ip-api.com (45 req/min, HTTP only).
IP_API_KEY=

POSTGRES_DB=voyager
POSTGRES_USER=voyager
POSTGRES_PASSWORD=voyager
